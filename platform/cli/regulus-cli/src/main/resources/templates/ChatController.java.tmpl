package {{package}};

import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestHeader;
import org.springframework.web.bind.annotation.RestController;

import java.util.Map;

/**
 * Minimal request entry point. Replace with your real agent invocation
 * once you've wired an ADK LlmAgent.
 */
@RestController
public class ChatController {

    @PostMapping("/chat")
    public Map<String, Object> chat(
            @RequestHeader(value = "X-Purpose-Code", required = false) String purposeCode,
            @RequestBody Map<String, Object> body) {
        // The Regulus plugins fire on the ADK App; this stub just echoes the
        // request so the audit trail can demonstrate redaction + attribution.
        return Map.of(
                "received", body,
                "purpose_code", purposeCode == null ? "missing" : purposeCode,
                "note", "Replace this stub with an ADK LlmAgent invocation."
        );
    }
}
